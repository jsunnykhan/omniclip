{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "omniclip-client",
  "version": "0.1.0",
  "identifier": "com.aekus.omniclip-client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "omniclip-client",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1REY4QUJCMENFMTAxMEIKUldRTEFlRU11NHJmbFVWQUtKRkVYZEJTbHNKRHowMTdmdDh3ZnIxRUdjVlA4SnZQY0FpSFF3YXYK",
      "endpoints": [
        "https://github.com/jsunnykhan/omniclip/releases/latest/download/latest.json"
      ]
    }
  }
}
